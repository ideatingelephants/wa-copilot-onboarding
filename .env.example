DATABASE_URL=postgres://postgres:postgres@localhost:5432/wa_ops_copilot

# Either OWNER_JID or OWNER_PHONE is required.
# Example OWNER_PHONE (digits only): 919876543210
OWNER_PHONE=
OWNER_JID=

# Directory where Baileys stores auth/session files.
AUTH_DIR=./auth

# Runtime behavior
LOG_LEVEL=info
TIMEZONE=Asia/Kolkata
ANALYZE_INTERVAL_MS=60000
ANALYZE_BATCH_SIZE=120
NUDGE_INTERVAL_MS=120000
HIGH_PRIORITY_THRESHOLD=3.5
CRITICAL_PRIORITY_THRESHOLD=6
MAX_NUDGES_PER_TICK=5
MAX_TASK_NUDGES_PER_TICK=5
STALE_TASK_HOURS=8
DIGEST_INTERVAL_MINUTES=240
DIGEST_LOOKBACK_HOURS=24
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# Optional LLM classifier.
# If ENABLE_LLM_CLASSIFIER=0, the bot uses only local heuristic+feedback learning.
# If ENABLE_LLM_CLASSIFIER=1, choose provider:
# - LLM_PROVIDER=gemini (recommended on GCP, via Vertex AI auth)
# - LLM_PROVIDER=openai
ENABLE_LLM_CLASSIFIER=0
LLM_PROVIDER=gemini
LLM_TIMEOUT_MS=20000

# OpenAI (used only when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Gemini on Vertex AI (used only when LLM_PROVIDER=gemini)
# Uses Application Default Credentials (ADC).
# For local runs: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-001

# Onboarding server (Google login -> create user GCP project -> deploy VM)
ONBOARDING_PORT=8787
ONBOARDING_BASE_URL=http://localhost:8787
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ONBOARDING_SESSION_TTL_HOURS=2
ONBOARDING_ALLOWED_EMAIL_DOMAINS=
AUTO_LOGOUT_AFTER_PROVISION=1

# Bootstrap deployment defaults for the onboarding flow.
# Repo must be publicly cloneable from the VM startup script.
BOOTSTRAP_REPO_URL=https://github.com/YOUR_ORG/OC-connect.git
BOOTSTRAP_REPO_BRANCH=main
BOOTSTRAP_DEFAULT_ZONE=asia-south2-a
BOOTSTRAP_DEFAULT_REGION=asia-south2
BOOTSTRAP_DEFAULT_TIMEZONE=Asia/Kolkata

# If billing accounts list is empty, users are sent here to create billing setup.
ONBOARDING_BILLING_SETUP_URL=https://console.cloud.google.com/billing/create

# Optional setup email (summary + pairing instructions + links).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
